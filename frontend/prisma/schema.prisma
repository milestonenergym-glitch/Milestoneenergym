generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ==========================================
// 1. AUTHENTICATION & USERS (NextAuth compatible)
// ==========================================

model Account {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  userId String  @db.ObjectId
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId String  @db.ObjectId
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          String    @default("ADMIN") // SUPER_ADMIN, ADMIN, MANAGER, TRAINER, MEMBER
  
  accounts      Account[]
  sessions      Session[]
  leads         Lead[]
  profile       MemberProfile?
  memberships   Membership[]
  payments      Payment[]
  
  trainerProfile TrainerProfile?
  classesTaught  GymClass[]
  attendanceRecords Attendance[]
  blogPosts      BlogPost[]
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model VerificationToken {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ==========================================
// 2. WEBSITE CMS & SETTINGS
// ==========================================

model GymSettings {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  gymName         String   @default("Milestone Energym")
  logoUrl         String   @default("/logo.jpg")
  contactPhone    String   @default("+91 8875305442")
  contactEmail    String   @default("Milestonenergym@gmail.com")
  address         String   @default("नवलाराम की चक्की, Near Crown Plaza NH68 जैसलमेर रोड बाड़मेर, Barmer, Rajasthan-344001")
  googleMapsUrl   String?
  facebookUrl     String?
  instagramUrl    String?
  youtubeUrl      String?
  
  // Business Hours (JSON stringified array)
  businessHours   String?  @default("[{\"day\":\"Monday - Saturday\",\"time\":\"5:30 AM - 10:30 PM\"},{\"day\":\"Sunday\",\"time\":\"Closed / Off\"}]")

  // Marketing Popup Feature
  customPopupHtml String?
  customPopupActive Boolean @default(false)

  // Analytics
  googleAnalyticsId String?
  metaPixelId       String?

  updatedAt       DateTime @updatedAt
}

model HeroBanner {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  imageUrl    String
  title       String?
  subtitle    String?
  badgeText   String?
  buttonText  String?
  buttonUrl   String?
  isActive    Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Testimonial {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  role        String?  @default("Member")
  content     String
  rating      Int      @default(5)
  imageUrl    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model GalleryImage {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  imageUrl    String
  category    String   @default("Facility") // Facility, Equipment, Classes
  title       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model BlogPost {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  slug        String   @unique
  content     String
  excerpt     String?
  imageUrl    String?
  isPublished Boolean  @default(false)
  
  authorId    String   @db.ObjectId
  author      User     @relation(fields: [authorId], references: [id])
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==========================================
// 3. CRM & LEADS
// ==========================================

model Lead {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  firstName   String
  lastName    String
  email       String
  phone       String?
  subject     String?
  message     String?
  pincode     String?
  source      String   @default("WEBSITE_CONTACT") // WEBSITE_CONTACT, POPUP, WALK_IN, WHATSAPP, FACEBOOK, INSTAGRAM
  status      String   @default("NEW") // NEW, CONTACTED, INTERESTED, TRIAL, JOINED, LOST
  notes       String?  // Staff follow-up notes
  
  assignedToId String? @db.ObjectId
  assignedTo   User?   @relation(fields: [assignedToId], references: [id])
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==========================================
// 4. MEMBERS & PLANS
// ==========================================

model Plan {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  name            String   // e.g., "1 Month Gold", "1 Year VIP"
  description     String?
  price           Float
  originalPrice   Float?
  durationInDays  Int      // e.g., 30, 90, 365
  features        String?  // JSON stringified array of benefits
  notIncluded     String?  // JSON stringified array of things not included
  popular         Boolean  @default(false)
  colorTheme      String?  // e.g. '#0F52BA' or 'blue'
  isActive        Boolean  @default(true)
  
  memberships     Membership[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model MemberProfile {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  userId String    @unique @db.ObjectId
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  phone             String?
  dateOfBirth       DateTime?
  gender            String?
  address           String?
  emergencyContact  String?
  bloodGroup        String?
  medicalConditions String?
  aadharNumber      String?
  height            String?
  weight            String?
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Membership {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  
  userId String  @db.ObjectId
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  planId String @db.ObjectId
  plan        Plan     @relation(fields: [planId], references: [id])
  
  startDate   DateTime
  endDate     DateTime
  status      String   @default("ACTIVE") // ACTIVE, EXPIRING, EXPIRED, CANCELLED
  
  amountPaid  Float
  paymentMode String   @default("CASH") // CASH, UPI, CARD
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==========================================
// 5. PAYMENTS & TRANSACTIONS
// ==========================================

model Payment {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  
  userId String  @db.ObjectId
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  amount      Float
  status      String   @default("SUCCESS") // SUCCESS, PENDING, FAILED
  paymentMode String   @default("CASH")    // CASH, UPI, CARD
  description String?  // e.g., "1 Year VIP Plan Payment"
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==========================================
// 6. CLASSES, TRAINERS & ATTENDANCE
// ==========================================

model TrainerProfile {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  userId String    @unique @db.ObjectId
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  specialization    String?  // e.g., Yoga, Powerlifting
  experienceYears   Int      @default(0)
  bio               String?
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model GymClass {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  description String?
  scheduleTime String? // Optional legacy field
  day         String?  // e.g., 'Mon', 'Tue'
  time        String?  // e.g., '06:00 AM'
  duration    String?  // e.g., '60 min'
  classType   String?  // e.g., 'Yoga', 'CrossFit'
  capacity    Int      @default(20)
  
  trainerId   String?  @db.ObjectId
  trainer     User?    @relation(fields: [trainerId], references: [id])
  
  isActive    Boolean  @default(true)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Attendance {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  
  userId String  @db.ObjectId
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  date        DateTime @default(now())
  
  @@index([userId, date])
}


